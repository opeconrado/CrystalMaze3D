# This .gitignore is configured for Unity projects.

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
[Mm]emoryCaptures/

# Recordings can get excessive in size.
[Rr]ecordings/

# Uncomment this line if you want to ignore the asset store tools plugin.
# [Aa]ssets/AssetStoreTools*

# Autogenerated JetBrains Rider plugin.
[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache/options
.vs/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated meta crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# OS generated
.DS_Store
.DS_Store?
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
